# API settings
API_V1_STR="/api/v1"
PROJECT_NAME="AuthNexus"

# CORS settings (comma-separated list)
CORS_ORIGINS="http://localhost:3000,https://authnexus.io,https://app.authnexus.io"

# Supabase settings
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"
SUPABASE_BUCKET="documents"

# AI model settings
AI_MODEL_PATH="models/document_verify_v1"
OCR_CONFIDENCE_THRESHOLD=0.85

# Sui blockchain settings
SUI_RPC_URL="https://fullnode.devnet.sui.io:443"
SUI_PACKAGE_ID="0x..."
SUI_PRIVATE_KEY="your-sui-private-key"

# n8n automation settings
N8N_WEBHOOK_URL="https://n8n.your-domain.com/webhook/authnexus"
N8N_API_KEY="your-n8n-api-key"

# Salesforce OAuth settings
SALESFORCE_CLIENT_ID="your-salesforce-client-id"
SALESFORCE_CLIENT_SECRET="your-salesforce-client-secret"
SALESFORCE_AUTH_URL="https://login.salesforce.com"
SALESFORCE_TOKEN_URL="https://login.salesforce.com/services/oauth2/token"
SALESFORCE_CALLBACK_URL="http://localhost:8000/api/v1/auth/oauth/callback"
